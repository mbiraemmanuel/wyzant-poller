# Authentication — use ONE of the two methods below.

# Option A: Paste the full Cookie header from your browser (expires, must refresh manually)
# WYZANT_COOKIE=session=abc123; _ga=GA1.2.xxx; ...

# Option B: Email + password — Playwright logs in automatically and keeps the session fresh.
WYZANT_EMAIL=coduor@makiniconsulting.com
WYZANT_PASSWORD=e2d6aSx!cgEYAkS

# Jobs board
JOBS_URL=https://www.wyzant.com/tutor/jobs
# JOBS_JSON_ENDPOINT=   # set this once you find the XHR endpoint via DevTools

# Notifications (ntfy — free, no account needed)
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=my-wyzant-alerts   # pick something unique

# Polling interval in seconds (must be >= 150)
POLL_MIN=150
POLL_MAX=210

# Persistent state directory (use /data on Railway with a volume attached)
STATE_DIR=/data

# Email notifications (optional — Gmail App Password)
# Generate an App Password at: myaccount.google.com → Security → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-gmail@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM=your-gmail@gmail.com
EMAIL_TO=coduor@makiniconsulting.com

# Logging
LOG_LEVEL=INFO
TZ=America/New_York
